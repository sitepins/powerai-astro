---
import Base from "@/layouts/Base.astro";
import MainContainer from "@/components/MainContainer";
import PageHeader from "@/partials/PageHeader";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ data, id }) => !data?.draft && !id.startsWith("-"));
  return pages.map((page) => ({
    params: { regular: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;

// Draft redirect
if ((page.data as any).draft) return Astro.redirect("/404");

const { Content } = await render(page);

const { title, meta_title, description, image, page_header } = page.data as any;
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  {page_header && <PageHeader page_header={page_header} client:load />}
  <section>
    <MainContainer>
      <div class="container-padding-x container-padding-y">
        <div class="content">
          <Content />
        </div>
      </div>
    </MainContainer>
  </section>
</Base>
