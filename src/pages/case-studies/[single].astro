---
import Base from "@/layouts/Base.astro";
import FeaturedCaseStudy from "@/components/FeaturedCaseStudy";
import MainContainer from "@/components/MainContainer";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const caseStudies = await getCollection("case-studies", ({ data, id }) => !data?.draft && !id.startsWith("-"));
  return caseStudies.map((study) => ({
    params: { single: study.id },
    props: { caseStudy: study },
  }));
}

const { caseStudy } = Astro.props;

// Draft redirect
if (caseStudy.data.draft) return Astro.redirect("/404");

const { Content } = await render(caseStudy);

const { title, meta_title, description, image } = caseStudy.data;

// Shape compatible with FeaturedCaseStudy component
const caseStudyForComponent = {
  frontmatter: caseStudy.data,
  slug: caseStudy.id,
  content: caseStudy.body || "",
};
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <section>
    <MainContainer>
      <div class="container-padding-x container-padding-y pb-14">
        <FeaturedCaseStudy data={caseStudyForComponent as any} hideButton disableLink client:visible />
      </div>
    </MainContainer>
  </section>
  <section>
    <MainContainer>
      <div class="container-padding-x py-12">
        <div class="lg:w-3/5 mx-auto">
          <div class="content">
            <Content />
          </div>
        </div>
      </div>
    </MainContainer>
  </section>
</Base>
